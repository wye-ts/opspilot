# Required for the live Claude spike (pnpm run spike:claude) and the live
# RAG spike (pnpm run spike:rag).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Required only for the live RAG spike (pnpm run spike:rag).
VOYAGE_API_KEY=

# Optional for the live RAG spike — validated defaults are used if unset.
# EMBEDDING_DIMENSIONS must be one of: 256, 512, 1024, 2048.
EMBEDDING_MODEL=voyage-4-lite
EMBEDDING_DIMENSIONS=1024

# Optional for the live RAG spike — selects which scenario(s) to run.
# RAG_SPIKE_SCENARIO must be one of: all, baseline, injection. Defaults to
# "all" if unset.
RAG_SPIKE_SCENARIO=all
