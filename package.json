{
  "name": "opspilot",
  "version": "0.1.0",
  "private": true,
  "description": "AI support and incident resolution agent",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "lint": "pnpm -r --if-present run lint",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:down:reset": "docker compose down -v",
    "db:test:ensure": "bash scripts/ensure-test-database.sh",
    "db:generate": "pnpm --filter @opspilot/database run db:generate",
    "db:migrate:dev": "pnpm --filter @opspilot/database run db:migrate:dev",
    "db:migrate:deploy": "pnpm --filter @opspilot/database run db:migrate:deploy",
    "db:migrate:status": "pnpm --filter @opspilot/database run db:migrate:status",
    "db:migrate:drift": "pnpm --filter @opspilot/database run db:migrate:drift",
    "db:migrate:test": "pnpm --filter @opspilot/database run db:migrate:test",
    "db:reset:dev": "pnpm --filter @opspilot/database run db:reset:dev",
    "db:reset:test": "pnpm --filter @opspilot/database run db:reset:test"
  },
  "packageManager": "pnpm@11.13.1",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}