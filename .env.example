# Local PostgreSQL (see docker-compose.yml). Copy this file to .env at the
# repo root — .env is gitignored — and adjust only if you changed
# docker-compose.yml's credentials or port mapping.
#
# Host port 55432 (not the default 5432) — this avoids conflicting with a
# pre-existing local Postgres instance some developer machines already run
# on 5432. The container's internal port is still the standard 5432.
DATABASE_URL=postgres://opspilot:opspilot_local_dev_only@localhost:55432/opspilot
TEST_DATABASE_URL=postgres://opspilot:opspilot_local_dev_only@localhost:55432/opspilot_test

# Used only by `pnpm db:migrate:drift` (prisma migrate diff), which needs a
# throwaway database to replay the committed migrations into for comparison.
# `pnpm db:test:ensure` creates this database itself (it does NOT get
# created automatically by Prisma) — Prisma only uses/resets its contents
# as the migration-diff comparison target once it already exists.
SHADOW_DATABASE_URL=postgres://opspilot:opspilot_local_dev_only@localhost:55432/opspilot_shadow
